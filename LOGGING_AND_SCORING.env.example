# =========================
# Genel log ayarları
# =========================

# Logların yazılacağı klasör. Proje köküne göre göreli olabilir.
LOG_DIR=logs

# DEBUG | INFO | WARN | ERROR
# INFO önerilir. DEBUG daha ayrıntılı fakat daha büyük dosya üretir.
LOG_LEVEL=INFO

# Konsola da yazılsın mı?
LOG_CONSOLE=true

# Genel yapılandırılmış JSONL logu üret.
LOG_JSON=true

# Her kayıttan sonra diske flush eder. Ani kapanmalarda log kaybını azaltır,
# fakat çok yoğun logda küçük bir I/O maliyeti oluşturur.
LOG_FLUSH_EACH_WRITE=true

# Bu süreden eski polybot-* loglarını başlangıçta ve gün değişiminde siler.
# 0 yapılırsa otomatik silme kapatılır.
LOG_RETENTION_DAYS=14

# =========================
# Reward scoring izleme
# =========================

# Emir açıldıktan sonra ilk scoring sorgusuna kadar beklenecek süre.
SCORING_INITIAL_DELAY_SECONDS=6

# Bu süre içindeki scoring=false cevapları hata sayılmaz.
SCORING_GRACE_SECONDS=45

# Scoring endpoint sorgu aralığı.
SCORING_CHECK_SECONDS=5

# Grace sonrasında art arda bu kadar scoring=false sonucu gelirse requote yapılır.
MAX_CONSECUTIVE_NOT_SCORING=3

# Scoring endpoint art arda bu kadar hata verdiğinde ERROR seviyesinde
# endpoint_degraded olayı yazılır. Emir yalnızca bunun yüzünden iptal edilmez.
SCORING_ERROR_WARN_THRESHOLD=3
