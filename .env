POLYMARKET_PRIVATE_KEY=c1762166d5d5bfd966f5284d670a6b7b1cd6cebb1fc040b9c55d2a2972194a9a
POLYMARKET_FUNDER_ADDRESS=0xD4FB15FE6F67Bc0aC3385F3235895b93B47E06F5
# 1=POLY_PROXY, 2=GNOSIS_SAFE, 3=POLY_1271
POLYMARKET_SIGNATURE_TYPE=3


# Önce dry-run ile doğrulayın.
LIVE_TRADING=true


# Ortak endpoint ayarları
CLOB_API_URL=https://clob.polymarket.com
MARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Quote / koruma
QUOTE_INSIDE_TICKS=1 # Reward max-spread sınırından kaç tick içeriye BUY yazılacağını belirler; 0 sınırı hedefler ve sınırda reward skoru sıfır olabilir.
MIN_PROTECTIVE_DEPTH=15 # Bizim BUY fiyatımızdan daha iyi seviyelerde bulunması gereken minimum efektif toplam share miktarıdır.
PROTECTIVE_DEPTH_LEVEL_CAP=50 # Tek bir fiyat seviyesinin koruyucu derinlik hesabına en fazla kaç share katkı yapabileceğini sınırlar.
PROTECTIVE_DEPTH_MIN_RETENTION_RATIO=0.60 # Emir açılışındaki efektif koruyucu miktarın en az hangi oranının korunması gerektiğini belirler.
PROTECTIVE_DEPTH_BREACH_CONFIRMATIONS=2 # Göreli koruyucu miktar eşiği ihlalinin kaç gerçek book güncellemesinde doğrulanınca iptal edileceğini belirler.
REPRICE_TOLERANCE_TICKS=0.50 # Yeni hesaplanan reward-edge fiyatı mevcut emirden bu kadar tick veya daha fazla saparsa cancel/requote yapılır.
CANCEL_MIN_DISTANCE_TICKS=0.50 # Midpoint mevcut BUY emrine bu kadar tickten fazla yaklaşırsa adverse-selection riski nedeniyle emir iptal edilir.
MAX_LIVE_SPREAD=0.06 # Canlı best ask ile best bid arasındaki izin verilen maksimum farktır; 0.06 = 6 cent.

# Emir başına maksimum sermaye
# Bot share miktarını reward minimum size ile CLOB minimum size arasından büyük olanla belirler.
# Bakiye için kod içinde %5 güvenlik payı bırakılır.
POLYMARKET_MAX_ORDER_USD=20

# Emir ve scoring izleme
ORDER_POLL_MILLISECONDS=1000
SCORING_CHECK_SECONDS=5

# Başlangıçta hesaptaki tüm açık emirleri iptal eder.
# Aynı cüzdanda başka emirler varsa false bırakın.
CANCEL_ALL_ON_START=true
